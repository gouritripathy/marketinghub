{
  "name": "marketinghub",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier -w .",
    "db:generate": "pnpm --filter @marketinghub/db prisma:generate",
    "db:migrate": "pnpm --filter @marketinghub/db prisma:migrate",
    "db:seed": "pnpm --filter @marketinghub/db prisma:seed"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8"
  }
}
